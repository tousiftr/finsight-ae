R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_r2_bucket_name
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_REGION=auto

DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require
NEON_DATABASE_URL="postgresql://user:password@host:5432/FinSight%20Analytics?sslmode=require&channel_binding=require"

MIXPANEL_PROJECT_ID="your_mixpanel_project_id"
MIXPANEL_SERVICE_ACCOUNT_USER="your_mixpanel_service_account_username"
MIXPANEL_SERVICE_ACCOUNT_SECRET="your_mixpanel_service_account_secret"
MIXPANEL_REGION=api
MIXPANEL_BATCH_SIZE=100
MIXPANEL_EXPORT_TABLE=dbt_fs.mixpanel_events_export
MIXPANEL_DRY_RUN=true
DBT_PRODUCT_ANALYTICS_SELECTOR=tag:product_analytics_hourly
