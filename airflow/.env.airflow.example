# Airflow UI
AIRFLOW_ADMIN_USER=rad
AIRFLOW_ADMIN_PASSWORD=change_this_strong_password
AIRFLOW_ADMIN_EMAIL=you@example.com
AIRFLOW_SECRET_KEY=change_this_to_a_long_random_secret
AIRFLOW_BASE_URL=http://127.0.0.1:8082

# FinSight repo path mounted inside Airflow containers
PROJECT_ROOT=/opt/airflow/finsight

# Warehouse
DATABASE_URL="postgresql://user:password@host:5432/FinSight%20Analytics?sslmode=require&channel_binding=require"
NEON_DATABASE_URL="postgresql://user:password@host:5432/FinSight%20Analytics?sslmode=require&channel_binding=require"

# dbt profile overrides (optional depending on profiles.yml strategy)
DBT_PROFILES_DIR=/opt/airflow/finsight/dbt_fintech
DBT_PG_HOST=your_neon_host
DBT_PG_USER=your_neon_user
DBT_PG_PASSWORD=your_neon_password
DBT_PG_PORT=5432
DBT_PG_DATABASE=FinSight Analytics

# Mixpanel sync
MIXPANEL_PROJECT_ID="your_mixpanel_project_id"
MIXPANEL_SERVICE_ACCOUNT_USER="your_mixpanel_service_account_username"
MIXPANEL_SERVICE_ACCOUNT_SECRET="your_mixpanel_service_account_secret"
MIXPANEL_REGION=api
MIXPANEL_BATCH_SIZE=2000
MIXPANEL_EXPORT_TABLE=dbt_fs.mixpanel_events_export
MIXPANEL_DRY_RUN=false
DBT_PRODUCT_ANALYTICS_SELECTOR=tag:product_analytics_hourly
MIXPANEL_BACKFILL_START_AT=2026-03-01 00:00:00
