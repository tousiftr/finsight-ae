# Airflow UI
AIRFLOW_ADMIN_USER=rad
AIRFLOW_ADMIN_PASSWORD=change_this_strong_password
AIRFLOW_ADMIN_EMAIL=you@example.com
AIRFLOW_SECRET_KEY=change_this_to_a_long_random_secret
AIRFLOW_BASE_URL=http://127.0.0.1:8082

# FinSight project path inside the Airflow containers
PROJECT_ROOT=/opt/finsight-ae

# Neon / warehouse connection placeholders
DATABASE_URL=postgresql://user:password@host:5432/FinSight%20Analytics?sslmode=require
NEON_DATABASE_URL=postgresql://user:password@host:5432/FinSight%20Analytics?sslmode=require

# dbt placeholders
DBT_PROFILES_DIR=/opt/finsight-ae/dbt_fintech
DBT_PG_HOST=your_neon_host
DBT_PG_USER=your_neon_user
DBT_PG_PASSWORD=your_neon_password
DBT_PG_PORT=5432
DBT_PG_DATABASE=FinSight Analytics

# Cloudflare R2 placeholders. Not used by the healthcheck DAG.
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=finsight-raw
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_REGION=auto
