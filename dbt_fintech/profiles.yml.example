finsight_fintech:
  target: dev
  outputs:
    dev:
      type: postgres
      host: "{{ env_var('DBT_PG_HOST', 'your-neon-host.neon.tech') }}"
      user: "{{ env_var('DBT_PG_USER', 'your_neon_user') }}"
      password: "{{ env_var('DBT_PG_PASSWORD', 'your_neon_password') }}"
      port: "{{ env_var('DBT_PG_PORT', '5432') | int }}"
      dbname: "{{ env_var('DBT_PG_DATABASE', 'your_database') }}"
      schema: dbt_rad
      sslmode: require
      threads: 4
